  "keyFeatures": [
    "Hardware detection (RAM, CPU, multi-GPU with NVIDIA/AMD/Intel/Apple Silicon)",
    "Interactive TUI with real-time model filtering and search",
    "Dynamic quantization selection (Q8_0 to Q2_K) based on available memory",
    "Multi-dimensional scoring across quality, speed, fit, and context",
    "MoE (Mixture-of-Experts) architecture support with expert offloading",
    "Speed estimation using GPU memory bandwidth for 80+ GPUs",
    "Provider integration (Ollama, llama.cpp, MLX) with install detection",
    "Plan mode for hardware requirement estimation",
    "REST API server for cluster scheduling and aggregation",
    "Database of 100+ models from HuggingFace with automatic updates"
  ],
  "publicApiSurface": [
    "llmfit (default TUI mode)",
    "llmfit --cli (classic table output)",
    "llmfit system (hardware specs)",
    "llmfit list (all models)",
    "llmfit fit [--perfect] [-n <limit>]",
    "llmfit search <query>",
    "llmfit info <model-name>",
    "llmfit recommend [--json] [--use-case <category>] [--limit <n>]",
    "llmfit plan <model-name> [--context <size>] [--quant <type>] [--target-tps <n>] [--json]",
    "llmfit serve [--host <addr>] [--port <n>]",
    "GET /health",
    "GET /api/v1/system",
    "GET /api/v1/models",
    "GET /api/v1/models/top",
    "GET /api/v1/models/{name}",
    "SystemSpecs::detect()",
    "ModelDatabase::new()",
    "ModelFit::analyze()",
    "OllamaProvider",
    "LlamaCppProvider",
    "MlxProvider"
  ]
